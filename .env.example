# -----------------------------------------------------------------------------
# Quantify AI Environment Configuration
# -----------------------------------------------------------------------------

# PORT: The port the full-stack server binds to (default: 3000)
PORT=3000

# NODE_ENV: Set to 'production' in live hosting, or 'development' during design
NODE_ENV=development

# JWT_SECRET: Strong secret key used for signing JWT-compliant ledger access tokens
# Required in production. Fail startup loudly if missing.
JWT_SECRET="quantify_production_secure_signing_secret_9988_xyz"

# GEMINI_API_KEY: Required for Gemini AI API calls (injected automatically in AI Studio UI)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The hosting address of this applet
APP_URL="http://localhost:3000"
